# SecureAuth Environment Variables Example

# Backend Secrets
JWT_SECRET_KEY=generate_a_random_high_entropy_secret_for_access_token_here
JWT_REFRESH_SECRET_KEY=generate_a_random_high_entropy_secret_for_refresh_token_here

# Social OAuth (Google)
# Set these to enable real Google Login, otherwise falls back to Mock profile in dev mode
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social OAuth (GitHub)
# Set these to enable real GitHub Login, otherwise falls back to Mock profile in dev mode
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP Mail Server (e.g. SendGrid, Mailgun, custom)
# If left empty, email codes will be logged directly to the backend uvicorn console
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_username@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@secureauth.dev
MAIL_FROM_NAME="SecureAuth Support"
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
